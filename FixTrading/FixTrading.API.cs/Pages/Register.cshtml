@page              
@model FixTrading.API.cs.Pages.RegisterModel
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <script>
        (function () {
            var t = localStorage.getItem('ft-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="/css/theme.css" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "tertiary":          "#3cddc7",
                        "on-tertiary-fixed": "#00201c",
                        "error":             "#ffb4ab",
                        "outline-variant":   "#45474b",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body":     ["Inter"],
                        "label":    ["Inter"]
                    }
                }
            }
        }
    </script>
</head>

<body class="ft-body font-body min-h-screen overflow-x-hidden selection:bg-tertiary/30">

    <!-- ── Tema Değiştirme Butonu ── -->
    <button class="ft-theme-toggle" onclick="toggleTheme()" title="Temayı değiştir">     
        <span class="material-symbols-outlined" id="toggleIcon">light_mode</span>
        <span id="toggleLabel">Light</span>
    </button>

    <main class="relative flex items-center justify-center min-h-screen ft-bg-mesh ft-dot-pattern p-6">

        <!-- Arka plan efektleri -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="ft-blob animate-pulse absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                        w-[800px] h-[600px] rounded-full blur-[140px]"></div>
            <img alt="Financial chart"
                 class="ft-chart filter grayscale contrast-125 blur-sm
                        absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                        w-[120%] max-w-none"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuB5miGh6Scq7tJKC-RV3-WnQ5BFkIUMqvwplY9MD0tQqBSp45SrILb9174NnDCDLhaRIj1Pr5fT3Y_YQigfLLa9FXg8AV48moVcdbOUXH7FBUccCivWfq3NmlDcJg0S61bNF1z4TjW8EBoxuCnpXIVn_You8RD6f-vwvnKaPRbZtqe-xi5ohVaeO43d0SGWGzhWZhKOSHNZpFgT3a_1bnz7KrEmZELp4BhMipu5qGlDGYcmbace325s6Ml7tnJkhEEmhwmrIw0oYDU" />
        </div>

        <!-- ── İçerik ── -->
        <div class="relative z-10 w-full max-w-[430px]">

            <!-- Logo -->
            <div class="text-center mb-8">
                <h1 class="font-headline text-4xl font-extrabold tracking-tighter italic ft-text"
                    style="letter-spacing: -0.03em;">
                    FixTrading
                </h1>
            </div>

            <!-- Kart -->
            <div class="ft-card w-full p-7 md:p-8 rounded-2xl">

                <header class="mb-7">
                    <!-- Geri butonu -->
                    <a href="/Login"
                       class="ft-link-accent inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-widest mb-4">
                        <span class="material-symbols-outlined text-sm">arrow_back</span>
                        Geri
                    </a>
                    <h2 class="font-headline text-2xl font-bold ft-text mb-2 text-center">
                        Hesap Oluştur
                    </h2>
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <p class="ft-error-box">@Model.ErrorMessage</p>
                    }
                </header>

                <form class="space-y-5" method="post">

                    <!-- Ad Soyad -->
                    <div class="space-y-2">
                        <label class="ft-label" for="name">Ad Soyad</label>
                        <div class="relative">
                            <span class="material-symbols-outlined ft-input-icon absolute left-4 top-1/2
                                         -translate-y-1/2 text-[18px]">person</span>
                            <input asp-for="Input.FullName"
                                   class="ft-input w-full rounded-xl py-3.5 pl-11 pr-5 text-sm font-body"
                                   id="name" placeholder="John Doe" type="text" />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="space-y-2">
                        <label class="ft-label" for="email">Email Adresi</label>
                        <div class="relative">
                            <span class="material-symbols-outlined ft-input-icon absolute left-4 top-1/2
                                         -translate-y-1/2 text-[18px]">mail</span>
                            <input asp-for="Input.Email"
                                   class="ft-input w-full rounded-xl py-3.5 pl-11 pr-5 text-sm font-body"
                                   id="email" placeholder="ornek@fixtrading.com" type="email" />
                        </div>
                    </div>

                    <!-- Şifre satırı -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="space-y-2">
                            <label class="ft-label" for="password">Şifre</label>
                            <div class="relative">
                                <span class="material-symbols-outlined ft-input-icon absolute left-4 top-1/2
                                             -translate-y-1/2 text-[18px]">lock</span>
                                <input asp-for="Input.Password"
                                       class="ft-input w-full rounded-xl py-3.5 pl-11 pr-3 text-sm font-body"
                                       id="password" placeholder="••••••••" type="password" />
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="ft-label" for="password_confirm">Tekrar</label>
                            <div class="relative">
                                <span class="material-symbols-outlined ft-input-icon absolute left-4 top-1/2
                                             -translate-y-1/2 text-[18px]">shield</span>
                                <input class="ft-input w-full rounded-xl py-3.5 pl-11 pr-3 text-sm font-body"
                                       id="password_confirm" placeholder="••••••••" type="password" />
                            </div>
                        </div>
                    </div>

                    <!-- Kullanım Koşulları -->
                    <div class="flex items-start gap-3 py-0.5">
                        <input class="mt-1 w-4 h-4 rounded text-tertiary focus:ring-tertiary/40 focus:ring-offset-0
                                      bg-transparent border-current"
                               id="terms" type="checkbox" style="border-color: var(--ft-input-border);" />
                        <label class="text-xs ft-text-faint leading-relaxed" for="terms">
                            <span class="ft-link-accent cursor-pointer">Kullanım koşullarını</span>
                            ve gizlilik politikasını kabul ediyorum.
                        </label>
                    </div>

                    <!-- Kayıt Ol Butonu -->
                    <div class="pt-1">
                        <button class="ft-btn-primary" type="submit">
                            Kayıt Ol
                            <span class="material-symbols-outlined text-lg">arrow_forward</span>
                        </button>
                    </div>
                </form>

                <div class="mt-6 ft-divider pt-5 text-center">
                    <p class="text-sm ft-text-faint">
                        Zaten hesabın var mı?
                        <a class="ft-link-accent font-semibold ml-1" href="/Login">
                            Giriş Yap
                        </a>
                    </p>
                </div>

            </div>
        </div>
    </main>

    <script>
        /* ── Tema Sistemi ── */
        function toggleTheme() {
            var curr = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = curr === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('ft-theme', next);
            syncToggleUI(next);
        }

        function syncToggleUI(theme) {
            var icon  = document.getElementById('toggleIcon');
            var label = document.getElementById('toggleLabel');
            if (!icon || !label) return;
            if (theme === 'light') {
                icon.textContent  = 'dark_mode';
                label.textContent = 'Dark';
            } else {
                icon.textContent  = 'light_mode';
                label.textContent = 'Light';
            }
        }

        syncToggleUI(document.documentElement.getAttribute('data-theme') || 'dark');
    </script>
</body>
</html>
