        /**
         * stepLimit(elId, delta): +/− butonuna basınca mevcut değere delta ekler.
         * Binlik virgülleri siler, ondalık noktasıyla işlem yapar ve geri formatlar.
         */
        function stepLimit(elId, delta) {
            var el = document.getElementById(elId);
            if (!el) return;
            var val = parseLimit(el);
            if (isNaN(val)) val = 0;
            
            var step = 1;
            if (val < 0.01) step = 0.00001;
            else if (val < 1) step = 0.001;
            else if (val < 10) step = 0.01;
            else if (val < 100) step = 0.1;
            
            var result = val + (delta * step);
            if (result < 0) result = 0;
            
            // DBeaver formatı ile geri yaz: 20,005.50 (Binlik Virgül, Ondalık Nokta)
            el.value = result.toLocaleString('en-US', { 
                minimumFractionDigits: 0, 
                maximumFractionDigits: 8 
            });
        }

        /**
         * parseLimit(el): Ekranda görünen DBeaver formatlı sayıyı (örn: 20,005.50) JavaScript sayısına çevirir.
         */
        function parseLimit(el) {
            if (!el) return NaN;
            var raw = el.value.trim().replace(/\s/g, '');
            if (!raw) return 0;

            // DBeaver format (20,005.50): virgülleri sil (binlik), noktayı ondalık al
            // Eğer virgül varsa binlik ayırıcı kabul ediyoruz
            raw = raw.replace(/,/g, '');
            
            return parseFloat(raw);
        }

        /* ═════ Limit sekmesi: sembol ekle / sil (REST, sayfa yenilenmeden) ═════ */
        function getAfToken() {
            var inp = document.querySelector('#ft-af-hold input[name="__RequestVerificationToken"]');
            return inp ? inp.value : '';
        }
        function showLimitsMsg(text, isError) {
            var box = document.getElementById('limits-symbol-msg');
            if (!box) return;
            if (!text) { box.classList.add('hidden'); box.textContent = ''; return; }
            box.classList.remove('hidden');
            box.textContent = text;
            box.style.background = isError ? 'rgba(255,113,107,0.1)' : 'rgba(0,253,147,0.08)';
            box.style.border = '1px solid ' + (isError ? 'rgba(255,113,107,0.35)' : 'rgba(0,253,147,0.28)');
            box.style.color = isError ? 'var(--ft-danger)' : 'var(--ft-secondary)';
        }
        function fmtLimitNum(n) {
            var x = Number(n);
            if (!Number.isFinite(x)) x = 0;
            return x.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 8 });
        }
        function escHtml(s) {
            return String(s)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/\"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
        function buildLimitTableRow(r) {
            var sym = r.symbol || '';
            var symShort = sym.length > 4 ? sym.substring(0, 4) : sym;
            var symDisp = sym.length === 6 ? sym.substring(0, 3) + '/' + sym.substring(3) : sym;
            var lid = r.limitId;
            var iid = r.instrumentId;
            var minS = fmtLimitNum(r.minMid);
            var maxS = fmtLimitNum(r.maxMid);
            var sprS = fmtLimitNum(r.maxSpread);
            var hMin = Number(r.minMid);
            var hMax = Number(r.maxMid);
            var hSp = Number(r.maxSpread);
            if (!Number.isFinite(hMin)) hMin = 0;
            if (!Number.isFinite(hMax)) hMax = 0;
            if (!Number.isFinite(hSp)) hSp = 0;
            return (
                '<tr>' +
                '<td><div style="display:flex;align-items:center;gap:12px">' +
                '<div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(105,218,255,0.15) 0%,rgba(105,218,255,0.04) 100%);border:1px solid rgba(105,218,255,0.2);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:800;color:var(--ft-primary);flex-shrink:0">' + escHtml(symShort) + '</div>' +
                '<div><div style="font-size:0.9rem;font-weight:700;color:var(--ft-text)">' + escHtml(symDisp) + '</div></div></div></td>' +
                '<td><div class="ft-spin-container"><input class="ft-input ft-spin-input" id="min-' + lid + '" inputmode="decimal" type="text" value="' + minS + '" style="color:var(--ft-secondary)" />' +
                '<div class="ft-spin-controls"><button type="button" class="ft-spin-btn" onclick="stepLimit(\'min-' + lid + '\', 1)">▲</button><button type="button" class="ft-spin-btn" onclick="stepLimit(\'min-' + lid + '\', -1)">▼</button></div></div></td>' +
                '<td><div class="ft-spin-container"><input class="ft-input ft-spin-input" id="max-' + lid + '" inputmode="decimal" type="text" value="' + maxS + '" style="color:var(--ft-text)" />' +
                '<div class="ft-spin-controls"><button type="button" class="ft-spin-btn" onclick="stepLimit(\'max-' + lid + '\', 1)">▲</button><button type="button" class="ft-spin-btn" onclick="stepLimit(\'max-' + lid + '\', -1)">▼</button></div></div></td>' +
                '<td><div class="ft-spin-container"><input class="ft-input ft-spin-input" id="spread-' + lid + '" inputmode="decimal" type="text" value="' + sprS + '" style="color:var(--ft-danger)" />' +
                '<div class="ft-spin-controls"><button type="button" class="ft-spin-btn" onclick="stepLimit(\'spread-' + lid + '\', 1)">▲</button><button type="button" class="ft-spin-btn" onclick="stepLimit(\'spread-' + lid + '\', -1)">▼</button></div></div></td>' +
                '<td><div style="display:flex;justify-content:flex-end;gap:6px">' +
                '<form method="post" action="/Admin?handler=UpdateLimit" onsubmit="return bindLimitValues(\'' + lid + '\')">' +
                '<input name="__RequestVerificationToken" type="hidden" value="' + escHtml(getAfToken()) + '" />' +
                '<input name="id" type="hidden" value="' + lid + '" />' +
                '<input id="hidden-min-' + lid + '" name="minMid" type="hidden" value="' + hMin + '" />' +
                '<input id="hidden-max-' + lid + '" name="maxMid" type="hidden" value="' + hMax + '" />' +
                '<input id="hidden-spread-' + lid + '" name="maxSpread" type="hidden" value="' + hSp + '" />' +
                '<button class="ft-btn-icon" title="Güncelle" type="submit" style="width:34px;height:34px;border-radius:10px;background:rgba(105,218,255,0.08);border-color:rgba(105,218,255,0.2);color:var(--ft-primary)" onmouseover="this.style.background=\'var(--ft-primary)\';this.style.color=\'var(--ft-primary-on)\'" onmouseout="this.style.background=\'rgba(105,218,255,0.08)\';this.style.color=\'var(--ft-primary)\'"><span class="material-symbols-outlined" style="font-size:16px">save</span></button></form>' +
                '<button class="ft-btn-icon ft-btn-delete-symbol" title="Sembolü sil (FIX + DB)" type="button" data-instrument-id="' + iid + '" style="width:34px;height:34px;border-radius:10px;background:rgba(255,113,107,0.08);border-color:rgba(255,113,107,0.2);color:var(--ft-danger)" onmouseover="this.style.background=\'var(--ft-danger)\';this.style.color=\'#fff\'" onmouseout="this.style.background=\'rgba(255,113,107,0.08)\';this.style.color=\'var(--ft-danger)\'"><span class="material-symbols-outlined" style="font-size:16px">delete</span></button>' +
                '</div></td></tr>'
            );
        }
        async function refreshLimitsTableFromApi() {
            var tb = document.getElementById('limitsTableBody');
            if (!tb) return;
            try {
                var res = await fetch('/api/admin/symbols', { credentials: 'same-origin', cache: 'no-store' });
                if (res.status === 401 || res.status === 403) { showLimitsMsg('Oturum gerekli veya yetkisiz.', true); return; }
                if (!res.ok) { showLimitsMsg('Sembol listesi alınamadı.', true); return; }
                var rows = await res.json();
                tb.innerHTML = (rows || []).map(buildLimitTableRow).join('');
                var foot = document.getElementById('limitsCountFoot');
                if (foot) foot.textContent = (rows || []).length + ' aktif limit ayarı';
            } catch (e) {
                console.warn(e);
                showLimitsMsg('Ağ hatası: liste güncellenemedi.', true);
            }
        }
        /**
         * Yeni Enstrüman Ekleme Formu Dinleyicisi
         * Form "submit" olduğunda (buton tıklandığında) devreye girer.
         */
        document.getElementById('addSymbolForm') && document.getElementById('addSymbolForm').addEventListener('submit', async function (e) {
            e.preventDefault(); // Sayfanın yenilenmesini engelle 
            
            var symInp = document.getElementById('addSymbolField');
            var symbol = symInp ? symInp.value.trim() : '';
            if (!symbol) { showLimitsMsg('Sembol girin.', true); return; }
            
            // Ekranda (virgüllü vb.) yazan sayıları saf sayıya çevir
            var minV = parseLimit({ value: document.getElementById('addMinMid').value });
            var maxV = parseLimit({ value: document.getElementById('addMaxMid').value });
            var spV = parseLimit({ value: document.getElementById('addMaxSpread').value });
            
            // Geçerli sayı olup olmadıklarını kontrol et
            if (isNaN(minV) || isNaN(maxV) || isNaN(spV)) { showLimitsMsg('Limit değerleri geçersiz.', true); return; }
            
            var btn = document.getElementById('addSymbolBtn');
            if (btn) btn.disabled = true; // İşlem bitene kadar butonu kilitle
            
            try {
                // POST isteği ile yeni sembolü arka plana (Backend) gönder
                var res = await fetch('/api/admin/symbols', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ symbol: symbol, minMid: minV, maxMid: maxV, maxSpread: spV })
                });
                
                var data = await res.json().catch(function () { return {}; });
                if (!res.ok) { showLimitsMsg(data.error || 'Eklenemedi.', true); return; }
                
                // Başarı mesajı göster ve form alanlarını temizle
                showLimitsMsg('Sembol eklendi.', false);
                symInp.value = '';
                document.getElementById('addMinMid').value = '';
                document.getElementById('addMaxMid').value = '';
                document.getElementById('addMaxSpread').value = '';
                
                // Tabloyu yeni eklenen sembolle beraber güncelle
                await refreshLimitsTableFromApi();
            } catch (err) {
                showLimitsMsg('Ağ hatası.', true);
            } finally {
                if (btn) btn.disabled = false; // Buton kilidini kaldır
            }
        });

        /**
         * Tablodaki "Sil" butonlarından birine tıklandığında çalışır.
         */
        document.addEventListener('click', async function (ev) {
            var t = ev.target;
            if (!t.closest) return;
            
            // Tıklanan yer bir silme butonu mu?
            var del = t.closest('.ft-btn-delete-symbol');
            if (!del || !del.getAttribute('data-instrument-id')) return;
            
            var iid = del.getAttribute('data-instrument-id');
            // Kullanıcıdan son onay al
            if (!confirm('Sembol ve limitler tamamen silinsin mi? ')) return;
            
            del.disabled = true;
            try {
                // DELETE isteği ile sembolü arka plandan kaldır
                var res = await fetch('/api/admin/symbols/' + encodeURIComponent(iid), { method: 'DELETE', credentials: 'same-origin' });
                if (res.status === 401 || res.status === 403) { showLimitsMsg('Yetkisiz işlem.', true); return; }
                if (!res.ok) { showLimitsMsg('Silinemedi.', true); return; }
                
                showLimitsMsg('Sembol silindi.', false);
                // Tabloyu güncel listeyle yenile
                await refreshLimitsTableFromApi();
            } catch (e) {
                showLimitsMsg('Ağ hatası.', true);
            } finally {
                del.disabled = false;
            }
        });

        /**
         * bindLimitValues(id): Limit GÜNCELLEME işlemi öncesi çalışır.
         * Ekranda görünen sayıları doğrular ve Backend'in beklediği formatta gizli inputlara aktarır.
         */
        function bindLimitValues(id) {
            var MAX_LIMIT = 9999999999;
            var minEl    = document.getElementById('min-' + id);
            var maxEl    = document.getElementById('max-' + id);
            var spreadEl = document.getElementById('spread-' + id);

            // Ekranda yazan sayıları sayı formatına çevir
            var minVal    = parseLimit(minEl);
            var maxVal    = parseLimit(maxEl);
            var spreadVal = parseLimit(spreadEl);

            // Değerlerin mantıklı aralıklarda olduğunu doğrula
            if (isNaN(minVal)    || minVal    < 0 || minVal    > MAX_LIMIT ||
                isNaN(maxVal)    || maxVal    < 0 || maxVal    > MAX_LIMIT ||
                isNaN(spreadVal) || spreadVal < 0 || spreadVal > MAX_LIMIT) {
                alert('Değerler 0 ile 9,999,999,999 arasında olmalıdır.\nOndalık: nokta (1.085) veya virgül (1,085) kullanabilirsiniz.');
                return false;
            }
            if (minVal > maxVal) {
                alert('Min Mid değeri Max Mid değerinden büyük olamaz.');
                return false;
            }

            // Doğrulanmış değerleri, form submit olduğunda gönderilecek olan gizli (hidden) inputlara aktar
            document.getElementById('hidden-min-' + id).value    = minVal.toString();
            document.getElementById('hidden-max-' + id).value    = maxVal.toString();
            document.getElementById('hidden-spread-' + id).value = spreadVal.toString();
            return true; // Her şey tamamsa formun gönderilmesine (submit) izin ver
        }

        var BADGE_KEY = 'ft-badges'; /* localStorage anahtarı */

        /** localStorage'dan rozet önbelleğini okur */
        function loadBadgeCache() {
            try { return JSON.parse(localStorage.getItem(BADGE_KEY) || '{}'); } catch(e) { return {}; }
        }

        /** Rozet önbelleğini localStorage'a yazar */
        function saveBadgeCache(cache) {
            try { localStorage.setItem(BADGE_KEY, JSON.stringify(cache)); } catch(e) {}
        }

        /* ── SAYFA AÇILINCA KAYITLI ROZETLERİ UYGULA ──
           Sayfa yenilense bile son bilinen değişim yönü gösterilir.
           Her sembol için hem tablo rozeti (data-change-badge)
           hem de strip rozeti (data-strip-badge) güncellenir. */
        (function applyStoredBadges() {
            var cache = loadBadgeCache();
            Object.keys(cache).forEach(function(symbol) {
                var b = cache[symbol];
                /* Market strip kartındaki rozet */
                var sBadge = document.querySelector('.ft-badge-stock[data-strip-badge="' + symbol + '"]');
                if (sBadge && b.cls && b.text) {
                    sBadge.className = 'ft-badge-stock ' + b.cls;
                    sBadge.textContent = b.text;
                    sBadge.style.display = 'inline-flex';
                }
                /* Canlı piyasa tablosundaki rozet */
                var cBadge = document.querySelector('.ft-badge-stock[data-change-badge="' + symbol + '"]');
                if (cBadge && b.cls && b.text) {
                    cBadge.className = 'ft-badge-stock ' + b.cls;
                    cBadge.textContent = b.text;
                    cBadge.style.display = 'inline-flex';
                }
            });
        })();

        /**
         * toNum(v): Herhangi bir değeri sayıya çevirir.
         * Geçersiz değer (NaN, undefined) gelirse 0 döner.
         */
        function toNum(v) { var n = Number(v); return Number.isFinite(n) ? n : 0; }

        /**
         * pulseCell(td, cls): Hücreye geçici renk animasyonu ekler.
         * cls = 'ft-cell-up' (yeşil) veya 'ft-cell-down' (kırmızı)
         * 800ms sonra animasyon sınıfı kaldırılır → yumuşak geçiş.
         */
        function pulseCell(td, cls) {
            td.classList.remove('ft-cell-up', 'ft-cell-down');
            if (cls) td.classList.add(cls);
            setTimeout(function () { td.classList.remove('ft-cell-up', 'ft-cell-down'); }, 800);
        }

        /**
         * applyBadge(symbol, cls, text)
         * Belirtilen sembole ait tüm rozet elementlerini günceller.
         * cls  → 'ft-badge-up' veya 'ft-badge-down'
         * text → '+0.05% ↑' veya '-0.03% ↓' gibi metin
         * Değerler localStorage önbelleğine de kaydedilir.
         */
        function applyBadge(symbol, cls, text) {
            /* Tablo içi rozet */
            var cBadge = document.querySelector('.ft-badge-stock[data-change-badge="' + symbol + '"]');
            if (cBadge) {
                cBadge.className = 'ft-badge-stock ' + cls;
                cBadge.textContent = text;
                cBadge.style.display = 'inline-flex';
            }
            /* Strip (fiyat bandı) rozeti */
            var sBadge = document.querySelector('.ft-badge-stock[data-strip-badge="' + symbol + '"]');
            if (sBadge) {
                sBadge.className = 'ft-badge-stock ' + cls;
                sBadge.textContent = text;
                sBadge.style.display = 'inline-flex';
            }
            /* localStorage önbelleğini güncelle */
            var cache = loadBadgeCache();
            cache[symbol] = { cls: cls, text: text };
            saveBadgeCache(cache);
        }

        // refreshMarket(): Canlı piyasa verilerini sunucudan alır ve tablo ile strip kartlarını günceller
        async function refreshMarket() {
            var table = document.getElementById('marketTable');
            if (!table) return; 
            try {
                var res = await fetch('/Admin?handler=LiveMarket', { cache: 'no-store' });
                if (!res.ok) return;
                var rows = await res.json();
                var body = table.querySelector('tbody');

                var activeSymbols = new Set(rows.map(function(r) { return r.symbol; }));

                // 1) Market Strip (üstteki kartlar) temizliği
                var stripCards = document.querySelectorAll('.ft-strip-card');
                stripCards.forEach(function(card) {
                    var sym = card.getAttribute('data-strip-symbol');
                    if (!activeSymbols.has(sym)) {
                        card.remove(); // Listede yoksa kartı sil
                    }
                });

                // 2) Market Tablosu (alt kısımdaki tablo) temizliği
                var tableRows = body.querySelectorAll('tr[data-symbol]');
                tableRows.forEach(function(tr) {
                    var sym = tr.getAttribute('data-symbol');
                    if (!activeSymbols.has(sym)) {
                        tr.remove(); // Listede yoksa satırı sil
                    }
                });

                rows.forEach(function (row) {
                    var tr = body.querySelector('tr[data-symbol="' + row.symbol + '"]');
                    if (!tr) {
                        tr = document.createElement('tr');
                        tr.setAttribute('data-symbol', row.symbol);
                        var symWithSlash = row.symbol.length === 6 ? row.symbol.substring(0,3) + '/' + row.symbol.substring(3) : row.symbol;
                        tr.innerHTML =
                            '<td style="text-align:center"><div style="display:flex;align-items:center;justify-content:center;gap:10px"><div class="ft-symbol-box">' + row.symbol.substring(0,4) + '</div><span style="font-weight:700;font-size:.88rem">' + symWithSlash + '</span></div></td>' +
                            '<td data-field="Bid" style="font-family:monospace;font-size:.88rem;text-align:center"></td>' +
                            '<td data-field="Ask" style="font-family:monospace;font-size:.88rem;text-align:center"></td>' +
                            '<td data-field="Mid" style="font-family:monospace;font-size:.88rem;text-align:center"><span></span><span class="ft-badge-stock" data-change-badge="' + row.symbol + '"></span></td>' +
                            '<td data-field="Spread" style="font-family:monospace;font-size:.88rem;color:var(--ft-text-muted);text-align:center"></td>';
                        body.appendChild(tr);
                    }

                    var stripCard = document.querySelector('.ft-strip-card[data-strip-symbol="' + row.symbol + '"]');
                    if (stripCard) stripCard.querySelector('.ft-strip-price').textContent = row.mid.toFixed(5);

                    ['Bid', 'Ask', 'Mid', 'Spread'].forEach(function (field) {
                        var td = tr.querySelector('td[data-field="' + field + '"]');
                        var textContainer = field === 'Mid' ? td.querySelector('span:first-child') : td;
                        var current = toNum(td.getAttribute('data-prev') || textContainer.textContent);
                        var next = toNum(row[field.toLowerCase()]);

                        if (field === 'Mid') {
                            if (current > 0 && next !== current) {
                                var diff = next - current;
                                var pct = ((diff / current) * 100).toFixed(2);
                                var isUp = diff > 0;
                                var cls = isUp ? 'ft-badge-up' : 'ft-badge-down';
                                var text = (isUp ? '+' : '') + pct + '% ' + (isUp ? '↑' : '↓');
                                applyBadge(row.symbol, cls, text);
                            }
                            textContainer.textContent = next.toFixed(5);
                        } else {
                            td.textContent = next.toFixed(5);
                        }

                        if (next > current) pulseCell(td, 'ft-cell-up');
                        if (next < current) pulseCell(td, 'ft-cell-down');

                        td.setAttribute('data-prev', String(next));
                    });
                });
            } catch (e) { console.warn('Market refresh error', e); }
        }

        /* İlk yüklemede hemen çalıştır, sonra 3 saniyede bir tekrarla */
        refreshMarket();
        setInterval(refreshMarket, 3000);
    </script>
</body>
</html>
