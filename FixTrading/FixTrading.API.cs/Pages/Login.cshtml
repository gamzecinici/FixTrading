@* ============================================================
   Login.cshtml — Giriş Sayfası
   Bu sayfa kullanıcıların sisteme giriş yapmasını sağlar.
   ASP.NET Core Razor Pages kullanılmaktadır.
   Model: Pages/Login.cshtml.cs → LoginModel sınıfı
   ============================================================ *@
@page
@model FixTrading.API.cs.Pages.LoginModel
<!DOCTYPE html>
@* lang="tr" → tarayıcıya sayfanın Türkçe olduğunu bildirir (ekran okuyucular vb. için önemli) *@
<html lang="tr">
<head>
    @* UTF-8 karakter seti: Türkçe karakterler (ğ, ş, ı, ö, ü, ç) düzgün görünsün diye *@
    <meta charset="utf-8" />
    @* Viewport: Mobil cihazlarda sayfanın tam genişlikte ve doğru zoom ile açılmasını sağlar *@
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <script>
        (function () {
            var t = localStorage.getItem('ft-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    @* Tailwind CSS CDN: Utility-first CSS framework.
       class="flex items-center gap-4" gibi kısayol sınıflarla
       hızlı layout yapmayı sağlar. *@
    <script src="https://cdn.tailwindcss.com"></script>

    @* Google Fonts:
       - Manrope      → Logo ve başlıklar için kalın, modern font
       - Inter        → Gövde metni ve formlar için okunaklı font
       - Material Symbols Outlined → ok, göz, güneş gibi simge (icon) seti *@
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    @* theme.css: Tüm renk değişkenleri (--ft-primary, --ft-bg vb.)
       ve paylaşılan bileşen stilleri burada tanımlıdır. *@
    <link href="/css/theme.css" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "tertiary":          "#3cddc7",
                        "on-tertiary-fixed": "#00201c",
                        "error":             "#ffb4ab",
                        "outline-variant":   "#45474b",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body":     ["Inter"],
                        "label":    ["Inter"]
                    }
                }
            }
        }
    </script>

    <style>
        /* .dot-overlay: Arka plan nokta efektini yerleşim akışından
           bağımsız tam kaplamak için kullanılan yardımcı sınıf.
           pointer-events:none → tıklamaları engellemiyor. */
        .dot-overlay { position: absolute; inset: 0; pointer-events: none; }
    </style>
</head>

@* ft-body         → theme.css'deki arka plan + yazı rengi uygulanır
   font-body       → Inter yazı tipi
   min-h-screen    → sayfa en az tam ekran yüksekliğinde
   overflow-x-hidden → yatay kaydırma çubuğu görünmesin
   selection:bg-tertiary/30 → metin seçilince turkuaz renk *@
<body class="ft-body font-body min-h-screen overflow-x-hidden selection:bg-tertiary/30">

    @* ── TEMA DEĞİŞTİRME BUTONU ──
       Sağ üst köşede sabit (fixed) durur.
       Tıklandığında toggleTheme() çağrılır (sayfanın altında tanımlı).
       İçindeki toggleIcon simgesi ve toggleLabel metni
       JavaScript ile güncellenir (light_mode ↔ dark_mode). *@
    <button class="ft-theme-toggle" onclick="toggleTheme()" title="Temayı değiştir">
        <span class="material-symbols-outlined" id="toggleIcon">light_mode</span>
        <span id="toggleLabel">Light</span>
    </button>

    @* ── ANA ALAN ──
       relative     → içindeki absolute öğeler buna göre konumlanır
       flex + items-center + justify-center → içeriği tam ortalar
       min-h-screen → tam ekran yüksekliği
       ft-bg-mesh   → iki radyal degrade arka plan efekti (sol üst + sağ alt)
       ft-dot-pattern → 28px aralıklı küçük nokta deseni
       p-6          → içerik kenara çok yakın durmasın diye boşluk *@
    <main class="relative flex items-center justify-center min-h-screen ft-bg-mesh ft-dot-pattern p-6">

        @* ── ARKAPLAN GÖRSEL EFEKTLERİ (pointer-events:none → tıklanamaz) ──  *@
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            @* ft-blob: Ortada yavaşça nefes alan (animate-pulse) bulanık
               ışıklı alan efekti. CSS gradient ile yapılmış, filtre blur ile
               yumuşatılmış. 800×600px büyük daire, tam ortada. *@
            <div class="ft-blob animate-pulse absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                        w-[800px] h-[600px] rounded-full blur-[140px]"></div>

            @* Finansal grafik görseli: Sayfanın tam ortasında,
               grayscale (siyah-beyaz) + düşük opacity + blur ile
               dekoratif arka plan olarak gösterilir.
               w-[120%] → konteynerden taşarak dolu alan kaplar. *@
            <img alt="Financial chart"
                 class="ft-chart filter grayscale contrast-125 blur-sm
                        absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                        w-[120%] max-w-none"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuB5miGh6Scq7tJKC-RV3-WnQ5BFkIUMqvwplY9MD0tQqBSp45SrILb9174NnDCDLhaRIj1Pr5fT3Y_YQigfLLa9FXg8AV48moVcdbOUXH7FBUccCivWfq3NmlDcJg0S61bNF1z4TjW8EBoxuCnpXIVn_You8RD6f-vwvnKaPRbZtqe-xi5ohVaeO43d0SGWGzhWZhKOSHNZpFgT3a_1bnz7KrEmZELp4BhMipu5qGlDGYcmbace325s6Ml7tnJkhEEmhwmrIw0oYDU" />
        </div>

        @* ── MERKEZDEKİ KART ALANI ──
           relative z-10 → arka plan efektlerinin önünde görünür
           max-w-[420px] → kartın çok geniş olmasını engeller *@
        <div class="relative z-10 w-full max-w-[420px] flex flex-col items-center">

            @* ── LOGO ALANI ──
               Kullanıcıya hangi sistemde olduğunu gösterir. *@
            <div class="mb-8 text-center">
                @* Büyük, kalın, italik "FixTrading" başlığı.
                   letter-spacing negatif → harfler sıkışık, modern görünüm. *@
                <h1 class="font-headline text-4xl font-extrabold tracking-tighter italic mb-1.5 ft-text"
                    style="letter-spacing: -0.03em;">
                    FixTrading
                </h1>
                @* Küçük slogan: büyük harf + geniş harf aralığı → kurumsal his *@
                <p class="ft-text-faint text-xs font-label uppercase tracking-[0.2em]">
                    Institutional Grade Security
                </p>
            </div>

            @* ── GİRİŞ KARTI ──
               ft-card → yarı saydam, bulanıklık filtreli glassmorphism kart
               p-8 rounded-2xl → iç boşluk ve yuvarlatılmış köşeler *@
            <div class="ft-card w-full p-8 rounded-2xl">

                <div class="mb-7">
                    <h2 class="font-headline text-2xl font-bold ft-text mb-2 text-center">
                        Giriş Yap
                    </h2>
                    @* Razor koşulu: Model.ErrorMessage boş değilse hata kutusunu göster.
                       Hata kutusu ft-error-box sınıfıyla kırmızı kenarlıklı bir kutu. *@
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <p class="ft-error-box">@Model.ErrorMessage</p>
                    }
                </div>

                @* ── GİRİŞ FORMU ──
                   method="post" → form verisi HTTP POST ile LoginModel.OnPostAsync'e gider.
                   space-y-5 → form alanları arasında dikey boşluk. *@
                <form class="space-y-5" method="post">

                    @* ── E-POSTA ALANI ── *@
                    <div class="space-y-2">
                        @* for="email" → label'a tıklayınca input'a odaklanır *@
                        <label class="ft-label" for="email">E-posta</label>
                        @* asp-for="Email" → LoginModel.Email özelliğine bağlı.
                           Sunucudan hata dönerse bu alana otomatik eski değer gelir.
                           type="email" → tarayıcı kendi doğrulamasını yapar. *@
                        <input asp-for="Email"
                               class="ft-input w-full rounded-xl py-3.5 px-5 text-sm font-body"
                               id="email" placeholder="ad@sirket.com" type="email" />
                    </div>

                    @* ── ŞİFRE ALANI ── *@
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="ft-label" for="password">Şifre</label>
                            <a class="ft-link-accent text-xs font-label" href="#">
                                Şifremi Unuttum
                            </a>
                        </div>
                        @* Göz butonu için relative konteyner:
                           Göz ikonu absolute ile input'un sağına yapıştırılır. *@
                        <div class="relative">
                            @* asp-for="Password" → LoginModel.Password özelliğine bağlı.
                               type="password" → karakterler ••• ile gizlenir.
                               pr-12 → sağ tarafta göz butonu için yer bırakılır. *@
                            <input asp-for="Password"
                                   class="ft-input w-full rounded-xl py-3.5 px-5 pr-12 text-sm font-body"
                                   id="passwordInput" placeholder="••••••••" type="password" />
                            @* Şifreyi göster/gizle butonu.
                               absolute right-4 top-1/2 -translate-y-1/2 → input'un tam ortasına yapışık.
                               onclick="togglePassword()" → aşağıdaki JavaScript fonksiyonunu çağırır. *@
                            <button class="absolute right-4 top-1/2 -translate-y-1/2 ft-input-icon
                                           hover:opacity-100 transition-opacity"
                                    type="button" onclick="togglePassword()">
                                <span class="material-symbols-outlined text-xl" id="eyeIcon">visibility</span>
                            </button>
                        </div>
                    </div>

                    @* ── GİRİŞ YAP BUTONU ──
                       type="submit" → form gönderilir, LoginModel.OnPostAsync çalışır.
                       ft-btn-primary → degrade renkli, animasyonlu ana buton stili. *@
                    <div class="pt-1">
                        <button class="ft-btn-primary" type="submit">
                            Giriş Yap
                            <span class="material-symbols-outlined text-lg">arrow_forward</span>
                        </button>
                    </div>
                </form>

                @* ── KAYIT OL LİNKİ ──
                   ft-divider → üst kenarda ince çizgi ayırıcı
                   Hesabı olmayan kullanıcıyı Register sayfasına yönlendirir. *@
                <div class="mt-8 ft-divider pt-6 text-center">
                    <p class="text-sm ft-text-faint">
                        Hesabın yok mu?
                        <a class="ft-link-accent font-semibold ml-1" href="/Register">
                            Kayıt Ol
                        </a>
                    </p>
                </div>

            </div>
        </div>
    </main>

    <script>
      
        /**
         * toggleTheme()
         * Tema düğmesine basılınca çalışır.
         * Mevcut temayı okur → tersine çevirir → <html data-theme> günceller
         * → localStorage'a kaydeder → buton görünümünü eşitler.
         */
        function toggleTheme() {
            var curr = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = curr === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            /* ft-theme anahtarıyla tarayıcıya kaydedilir.
               Sayfa yenilenince flash önleyici script buradan okur. */
            localStorage.setItem('ft-theme', next);
            syncToggleUI(next);
        }

        /**
         * syncToggleUI(theme)
         * Tema butonunun simgesini ve yazısını mevcut temaya göre ayarlar.
         * - Açık tema aktifken "Dark" yazar  → koyu moda geçiş yapılacağını gösterir
         * - Koyu tema aktifken  "Light" yazar → açık moda geçiş yapılacağını gösterir
         */
        function syncToggleUI(theme) {
            var icon  = document.getElementById('toggleIcon');
            var label = document.getElementById('toggleLabel');
            if (!icon || !label) return; /* Elementler yoksa çık (güvenlik önlemi) */
            if (theme === 'light') {
                icon.textContent  = 'dark_mode';   /* Güneş yerine ay simgesi */
                label.textContent = 'Dark';
            } else {
                icon.textContent  = 'light_mode';  /* Ay yerine güneş simgesi */
                label.textContent = 'Light';
            }
        }

        /* Sayfa ilk açıldığında buton görünümünü mevcut temayla eşitle */
        syncToggleUI(document.documentElement.getAttribute('data-theme') || 'dark');


        /**
         * togglePassword()
         * Şifre alanındaki göz butonuna basılınca çalışır.
         * input.type 'password' ↔ 'text' arasında değişir.
         * Simge de visibility ↔ visibility_off arasında değişir.
         */
        function togglePassword() {
            var input = document.getElementById('passwordInput');
            var icon  = document.getElementById('eyeIcon');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.textContent = input.type === 'password' ? 'visibility' : 'visibility_off';
        }
    </script>
</body>
</html>
